#!/bin/sh
# Pre-commit hook: keep the generated summaries in sync with property_data.json.
# Only rebuilds when the data file is part of this commit (so unrelated commits
# don't touch the HTML). Aborts the commit if the build fails.

if git diff --cached --name-only | grep -q '^property_data\.json$'; then
  echo "property_data.json changed -> running build.js..."
  if ! node build.js; then
    echo "build.js failed - commit aborted. Fix the error and try again." >&2
    exit 1
  fi
  # stage the regenerated artifacts so they're part of the same commit
  # NOTE: must list every file build.js writes, or a regenerated-but-unstaged
  # artifact will be left dirty in the working tree after the commit.
  git add property_summary.html property_summary_ru.html property_summary_amstelveen.html index.html
fi
